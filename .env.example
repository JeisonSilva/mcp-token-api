PORT=3000
DATABASE_PATH=./data/app.db

# Seed: cria usuário admin na primeira inicialização (opcional)
ADMIN_EMAIL=admin@exemplo.com
ADMIN_PASSWORD=troque_esta_senha
JWT_ACCESS_SECRET=troque_este_secret_com_minimo_32_caracteres


# API key generated by the REST API — paste the mcp_sk_... value returned by POST /apikeys
MCP_API_KEY=mcp_sk_replace_with_generated_key
