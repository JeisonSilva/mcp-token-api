{
  "name": "@jeison-mcp/mcp-token-api-mcp",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-token-api": "./index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build-release": "chmod 755 ./index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --experimental-strip-types index.ts",
    "inspect": "mcp-inspector node --experimental-strip-types index.ts",
    "typecheck": "tsc --noEmit",
    "verdaccio:release-bugfix": "npm version patch && npm publish --access public --registry http://localhost:4873",
    "verdaccio:release-feature": "npm version minor && npm publish --access public --registry http://localhost:4873",
    "verdaccio:release-break-change": "npm version major && npm publish --access public --registry http://localhost:4873",
    "verdaccio:unpublish": "npm unpublish --force --registry http://localhost:4873 @jeison-mcp/mcp-token-api-mcp",
    "verdaccio:login": "npm login --registry http://localhost:4873"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.4.0",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.3",
    "@langchain/openai": "^1.4.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "tsx": "^4.22.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.22.0",
    "@types/node": "^25.9.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
